{
  "name": "zotero-translate",
  "version": "0.1.0",
  "description": "LLM-first translation for Zotero. Translate PDF, EPub, metadata, annotations and notes with ChatGPT/Claude/Gemini and many OpenAI-compatible providers, plus free no-key fallback engines.",
  "config": {
    "addonName": "Zotero Translate",
    "addonID": "zotero-translate@niehu.github.io",
    "addonRef": "zoterotranslate",
    "prefsPrefix": "extensions.zotero.ZoteroTranslate",
    "addonInstance": "ZoteroTranslate"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "tsc --noEmit && zotero-plugin build",
    "release": "zotero-plugin release",
    "lint": "prettier --write . && eslint . --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "update-deps": "npm update --save"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agents365-ai/zotero-translate.git"
  },
  "author": "niehu",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Agents365-ai/zotero-translate/issues"
  },
  "homepage": "https://github.com/Agents365-ai/zotero-translate#readme",
  "dependencies": {
    "franc": "^6.2.0",
    "iso639-js": "^1.1.3",
    "jsencrypt": "^3.5.0",
    "katex": "^0.16.25",
    "zotero-plugin-toolkit": "^5.1.0-beta.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.16.5",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.48.1",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.3"
  }
}
